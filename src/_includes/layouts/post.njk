---
layout: layouts/base.njk
---
<article class="post">
  <section class="page-header">
    <div class="container">
      <h1>{{ title }}</h1>
      <time datetime="{{ date | dateFormat }}">{{ date | dateFormat }}</time>
    </div>
  </section>
  <section class="page-content">
    <div class="container">
      {{ content | safe }}
    </div>
  </section>
</article>
